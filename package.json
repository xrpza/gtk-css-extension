{
  "name": "gtk-css",
  "displayName": "GTK CSS",
  "description": "Syntax highlighting and IntelliSense for GTK-specific CSS: @define-color, color functions (alpha, shade, mix), -gtk- properties, and GTK widget element selectors.",
  "version": "1.3.0",
  "publisher": "mpmischitelli",
  "main": "./dist/client/extension.js",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "scripts": {
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "package": "vsce package",
    "vscode-prepublish": "npm run compile",
    "test": "node ./test/runTest.js"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "gtk",
    "css",
    "waybar",
    "gnome",
    "gtk3",
    "gtk4",
    "syntax highlighting",
    "define-color",
    "intellisense"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mmischitelli/gtk-css-extension"
  },
  "bugs": {
    "url": "https://github.com/mmischitelli/gtk-css-extension/issues"
  },
  "license": "MIT",
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-css-languageservice": "^6.3.3",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.0.8"
  },
  "contributes": {
    "languages": [
      {
        "id": "gtk-css",
        "aliases": [
          "GTK CSS",
          "gtk-css"
        ],
        "extensions": [
          ".gtk.css"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gtk-css",
        "scopeName": "source.gtk-css",
        "path": "./syntaxes/gtk-css.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "glob": "^8.1.0"
  }
}
